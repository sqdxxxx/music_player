<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/floatingView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="8dp"
    android:clickable="true"
    android:focusable="true">



    <ImageView
        android:id="@+id/floatingCover"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/floatingSongName"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="歌曲名称"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@id/floatingPlayButton"
        app:layout_constraintHorizontal_bias="0.426"
        app:layout_constraintStart_toEndOf="@id/floatingCover"
        app:layout_constraintTop_toTopOf="@id/floatingCover" />

    <TextView
        android:id="@+id/floatingSingerName"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="歌手"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@id/floatingSongName"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/floatingSongName"
        app:layout_constraintTop_toBottomOf="@id/floatingSongName" />

    <!-- 列表按钮（在后） -->

    <ImageView
        android:id="@+id/floatingPlayButton"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/ic_black_pause"
        app:layout_constraintBottom_toBottomOf="@id/floatingCover"
        app:layout_constraintEnd_toStartOf="@id/floatingPlaylistButton"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/floatingPlaylistButton"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_black_list"
        app:layout_constraintBottom_toBottomOf="@id/floatingCover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
